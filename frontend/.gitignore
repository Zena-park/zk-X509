# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Installers are NOT served from here anymore — /download links to the
# GitHub release, which is the only build that is signed and notarized.
# Hand-copying a local `tauri build` into public/downloads/ is what let a
# stale, adhoc-signed DMG sit on the site for two months; a local build
# has no signing identity, so Gatekeeper refuses whatever lands here.
# Kept only so a stray copy can't be committed by accident.
public/downloads/
