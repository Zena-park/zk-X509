{
  "name": "@tokamak-network/zk-x509-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK + CLI for integrating zk-X509 on-chain identity verification (prove an X.509 certificate identity with a ZK proof, then gate your dApp on it).",
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "zk-x509": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zk-x509",
    "identity",
    "ethereum",
    "x509",
    "zero-knowledge",
    "kyc",
    "verification",
    "ethers"
  ],
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ethers": "^6.16.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
