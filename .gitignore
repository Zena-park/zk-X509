# Cargo build
**/target

# App bundle output
dist/

# Cargo config
.cargo

# Profile-guided optimization
/tmp
pgo-data.profdata

# MacOS nuisances
.DS_Store

# Proofs
**/proof-with-pis.json
**/proof-with-io.json

# Env
.env
# All per-environment dotenv files (may contain secrets / deploy config).
# Keep .env.example tracked as the committed template.
.env.*
!.env.example

# Firebase project selection. Names whoever's Firebase project this checkout
# deploys to, so it is per-deployer, not per-repo: committing it means a clone
# (or a fork) points `firebase deploy` at someone else's project by default.
# Copy .firebaserc.example and run `firebase use <project-id>` instead.
.firebaserc
!.firebaserc.example

# Node
node_modules/
.next/
out/

# Foundry
contracts/cache/
contracts/out/
contracts/broadcast/

# Test certs — all generated artifacts excluded
# Regenerate: cd certs && bash generate-test-certs.sh && bash generate-test-crl.sh
certs/**/*.key
certs/**/*.pem
certs/**/*.der

# Generated test fixtures
contracts/test/fixtures/groth16-fixture.json

# Generated CA public key copy
data/ca-certs/ca_pub.der
.env.local
.docker-addresses.json
elf/

# Dev anvil deploy output (per-session, not part of repo)
.env.shared-anvil

# Delegated-prover output. PROVER_LOG_DIR sets where it lands (default ./logs),
# so these are deliberately NOT anchored to the repo root — a custom log dir has
# to be caught too. The directory holds the ECIES private key that decrypts the
# certificate data clients send, plus compliance logs carrying real certificate
# PII (common name, org, serial, nullifier). Neither may ever be committed.
logs/
**/.ecies_key

# Dev server logs and emulator debug output. Tooling always writes these at the
# repo root, so anchor them rather than shadowing any same-named source dir.
/.dev-logs/
/firestore-debug.log
/firebase-debug.log

# Firebase CLI deploy cache
/.firebase/
