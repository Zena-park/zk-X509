# Cargo build
**/target

# App bundle output
dist/

# Cargo config
.cargo

# Profile-guided optimization
/tmp
pgo-data.profdata

# MacOS nuisances
.DS_Store

# Proofs
**/proof-with-pis.json
**/proof-with-io.json

# Env
.env
# All per-environment dotenv files (may contain secrets / deploy config).
# Keep .env.example tracked as the committed template.
.env.*
!.env.example

# Node
node_modules/
.next/
out/

# Foundry
contracts/cache/
contracts/out/
contracts/broadcast/

# Test certs — all generated artifacts excluded
# Regenerate: cd certs && bash generate-test-certs.sh && bash generate-test-crl.sh
certs/**/*.key
certs/**/*.pem
certs/**/*.der

# Generated test fixtures
contracts/test/fixtures/groth16-fixture.json

# Generated CA public key copy
data/ca-certs/ca_pub.der
.env.local
.docker-addresses.json
elf/

# Dev anvil deploy output (per-session, not part of repo)
.env.shared-anvil

# Delegated-prover ECIES private key. prover-server generates this on first run
# next to its log dir; it decrypts the certificate data clients send, so it must
# never be committed. Matched anywhere, since the log dir is configurable.
**/.ecies_key

# Runtime logs (prover-server compliance log, dev server logs, emulator debug)
logs/
script/logs/
.dev-logs/
firestore-debug.log
firebase-debug.log

# Firebase CLI deploy cache
.firebase/
