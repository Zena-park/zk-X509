cache/
out/

# Broadcast receipts, all networks. Foundry's template un-ignores /broadcast to
# keep deploy receipts under version control; this repo records deployments in
# deployments/<chainId>.json instead, so the raw receipts stay local-only. (This
# file wins over the root .gitignore for paths under contracts/, so the negation
# had to go here, not there.)
/broadcast/

