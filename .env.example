# ========= SP1 Prover =========
# Modes: mock, cpu, cuda, network
SP1_PROVER=cpu

# Succinct Prover Network key (for network mode)
# Setup: https://docs.succinct.xyz/docs/network/developers/key-setup
NETWORK_PRIVATE_KEY=

# ========= Deployment =========
RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# SP1 On-chain Verifier (check https://docs.succinct.xyz).
# Only read by the single-registry script/Deploy.s.sol. The RegistryFactory
# flow (DeployLocal.s.sol) deploys its own SP1VerifierGroth16 and ignores this.
# Sepolia Succinct gateway: 0x3B6041173B80E77f038f3F2C0f9744f04837185e
SP1_VERIFIER_ADDRESS=0x3B6041173B80E77f038f3F2C0f9744f04837185e

# Program verification key (from: cargo run --release --bin vkey).
# Required by both DeployLocal.s.sol and Deploy.s.sol.
PROGRAM_V_KEY=0x...

# ========= Registry parameters (DeployLocal/SeedLocal/Deploy) =========
# Max wallets per certificate (1=DAO, 3=DeFi)
MAX_WALLETS_PER_CERT=1

# Minimum required selective-disclosure bitmask (0x00–0x0F). 0 = no minimum.
MIN_DISCLOSURE_MASK=0

# Max accepted proof age in seconds (replay window). Default 3600.
MAX_PROOF_AGE=3600

# CA Merkle root (compute from allowed CA public keys; optional at deploy time).
CA_MERKLE_ROOT=0x...

# ========= Seeding a registry via the factory (SeedLocal.s.sol) =========
# Address of the deployed RegistryFactory.
FACTORY=0x...
# Human-readable service name for the registry instance (e.g. users, relayers).
SERVICE_NAME=users

# ========= Proof Generation =========
# Note: the CLI prover (zk-x509) takes these as flags (--chain-id, --registry-address);
# REGISTRY_ADDRESS below is read by script/verify-deployment.sh.
CHAIN_ID=11155111
REGISTRY_ADDRESS=0x...
